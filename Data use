def build_empty_local_image_text() -> Tuple[str, List[Path], List[Dict[str, Any]]]:
    local_image_text = """
NumValidViews: "0";
NumAnnotatedImages: "0";
ViewInformation: "Local image information is unavailable because bim_projection_contours.json is missing or no valid annotated image could be loaded.";
LocalImageRule: "No local image evidence is available for this element at the current time step.";
ViewPolygons: "";
""".strip()

    return local_image_text, [], []
def build_local_image_text(run_dir: Path, contour_json_path: Path) -> Tuple[str, List[Path], List[Dict[str, Any]]]:
    contour_data = read_json(contour_json_path)
    element_name = contour_data.get("element_name", "unknown_element")

    items: List[Dict[str, Any]] = [
        x for x in contour_data.get("items", [])
        if x.get("num_contours", 0) > 0
    ]

    # 内部仍然按相对投影规模排序，但不把 mask_area_ratio 原始数值暴露给模型
    items = sorted(
        items,
        key=lambda x: (
            float(x.get("mask_area_ratio", 0.0)),
            int(x.get("projected_points_unique_px", 0))
        ),
        reverse=True
    )

    annotated_imgs: List[Path] = []
    view_info_lines: List[str] = []
    view_polygon_lines: List[str] = []

    num_views = len(items)

    for i, item in enumerate(items, start=1):
        base = Path(item["image_name"]).stem
        png_path = run_dir / f"{element_name}_{base}_{item['side']}_.png"

        if png_path.exists():
            annotated_imgs.append(png_path)

        proj_pts = int(item.get("projected_points_unique_px", 0))
        side = item.get("side", "")
        img_name = item.get("image_name", "")
        contours = item.get("contours", [])
        num_contours = int(item.get("num_contours", 0))

        if num_views > 1:
            if i == 1:
                priority_note = "This is one of the strongest primary reference views among the available valid views."
            elif i <= min(3, num_views):
                priority_note = "This is a secondary but still important reference view among the available valid views."
            else:
                priority_note = "This is a supplementary reference view among the available valid views."

            view_info_lines.append(
                f"View {i}: side={side}, image={img_name}, "
                f"projected_points_unique_px={proj_pts}, num_contours={num_contours}. "
                f"{priority_note} "
                f"View priority is determined only relative to the other valid views and must not be interpreted as construction completion, geometric completeness, or visual coverage of the element."
            )
        else:
            view_info_lines.append(
                f"View {i}: side={side}, image={img_name}, "
                f"projected_points_unique_px={proj_pts}, num_contours={num_contours}. "
                f"Only one valid view is available. The judgment must rely directly on the visible target region inside the contour. "
                f"Do not describe the visual evidence as limited, weak, or low-confidence based on the relative projected area."
            )

        view_polygon_lines.append(
            f"View {i}: side={side}, image={img_name}, contours={json.dumps(contours, ensure_ascii=False)}"
        )

    view_info_text = "\n".join(view_info_lines)
    view_polygon_text = "\n".join(view_polygon_lines)

    if num_views > 1:
        local_rule = (
            "For each valid view, the target region is defined by the contour polygons in bim_projection_contours.json. "
            "The model should focus primarily on the contour-enclosed region in the annotated images. "
            "When multiple valid views are available, earlier listed views should be treated as stronger primary references relative to later listed views. "
            "This ordering is only for view prioritization and must not be interpreted as construction completion, geometric completeness, or visual coverage of the element."
        )
    else:
        local_rule = (
            "For the valid view, the target region is defined by the contour polygon in bim_projection_contours.json. "
            "The model should focus primarily on the contour-enclosed region in the annotated image. "
            "Since only one valid view is available, the assessment must rely directly on the visible target region in this view. "
            "Do not infer limited coverage, weak evidence, or low confidence from the relative projected size of the target region."
        )

    local_image_text = f"""
NumValidViews: "{len(items)}";
NumAnnotatedImages: "{len(annotated_imgs)}";
ViewInformation: "{safe(view_info_text)}";
LocalImageRule: "{safe(local_rule)}";
ViewPolygons: "{safe(view_polygon_text)}";
""".strip()

    return local_image_text, annotated_imgs, items


# =========================================================
# 5) 自动生成完整性说明
# =========================================================
def build_input_completeness(
    has_bim: bool,
    has_pc: bool,
    has_temporal: bool,
    has_local_image: bool,
) -> Tuple[int, str]:
    missing = []

    if not has_bim:
        missing.append("BIM semantic information")
    if not has_pc:
        missing.append("point cloud summary information")
    if not has_temporal:
        missing.append("temporal context information")
    if not has_local_image:
        missing.append("local image information")

    n = 4 - len(missing)

    if not missing:
        availability_text = "no input information is missing"
    elif len(missing) == 1:
        availability_text = f"{missing[0]} is unavailable"
    elif len(missing) == 2:
        availability_text = f"{missing[0]} and {missing[1]} are unavailable"
    else:
        availability_text = ", ".join(missing[:-1]) + f", and {missing[-1]} are unavailable"

    return n, availability_text


