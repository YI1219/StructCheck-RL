def _image_to_data_url(image_path: Path) -> str:
    mime_type, _ = mimetypes.guess_type(str(image_path))
    if mime_type is None:
        mime_type = "image/png"

    with open(image_path, "rb") as f:
        b64 = base64.b64encode(f.read()).decode("utf-8")

    return f"data:{mime_type};base64,{b64}"

def _clean_json_text(text: str) -> str:
    text = text.strip()

    if text.startswith("```json"):
        text = text[7:].strip()
    elif text.startswith("```"):
        text = text[3:].strip()

    if text.endswith("```"):
        text = text[:-3].strip()

    return text

def call_comp_openai_with_images(prompt: str, image_paths: List[Path]) -> Dict[str, Any]:
    api_key = "0fd224af298a4d919a5f3543a6a590dd"
    deploy_name = "gpt4o"

    if not api_key:
        raise EnvironmentError("COMP_OPENAI_KEY is not set.")

    # 你可以改成 gpt4o-mini / gpt41-mini / 其他已部署名称

    base = "https://comp.azure-api.net/azure"
    api_version = "2024-02-01"

    client = AzureOpenAI(
        api_key=api_key,
        api_version=api_version,
        base_url=f"{base}/openai/deployments/{deploy_name}",
    )

    user_content: List[Dict[str, Any]] = [
        {
            "type": "text",
            "text": prompt
        }
    ]

    for p in image_paths:
        try:
            data_url = _image_to_data_url(p)
            user_content.append(
                {
                    "type": "image_url",
                    "image_url": {
                        "url": data_url,
                        "detail": "auto"
                    }
                }
            )
        except Exception as e:
            print(f"[WARN] Failed to load image {p}: {e}")

    response = client.chat.completions.create(
        model=deploy_name,
        messages=[
            {
                "role": "system",
                "content": "You are a construction progress assessment assistant. Return valid JSON only, without markdown code fences."
            },
            {
                "role": "user",
                "content": user_content,
            },
        ],
        temperature=0.2,
    )

    text = response.choices[0].message.content
    if not text:
        raise RuntimeError("COMP OpenAI returned empty text.")

    cleaned_text = _clean_json_text(text)

    try:
        result = json.loads(cleaned_text)
    except json.JSONDecodeError:
        result = {
            "Stage_label": "",
            "Completion": "",
            "Reason": cleaned_text
        }

    return result


