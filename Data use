# 8) 主流程
# =========================================================
def main() -> None:
    if not META_PATH.exists():
        raise FileNotFoundError(f"meta.json not found: {META_PATH}")
    if not POINT_CLOUD_SUMMARY_PATH.exists():
        raise FileNotFoundError(f"point_cloud_summary.json not found: {POINT_CLOUD_SUMMARY_PATH}")

    target_element_text, bim_semantics = build_bim_semantics(META_PATH)
    pointcloud_summary_text = build_pointcloud_summary(POINT_CLOUD_SUMMARY_PATH)
    temporal_text = build_temporal_text(ELEMENT_DIR, RUN_DATE)

    if CONTOUR_JSON_PATH.exists():
        local_image_text, annotated_imgs, valid_items = build_local_image_text(RUN_DIR, CONTOUR_JSON_PATH)
    else:
        print(f"[WARN] bim_projection_contours.json not found: {CONTOUR_JSON_PATH}")
        print("[WARN] Local image information will be treated as missing.")
        local_image_text, annotated_imgs, valid_items = build_empty_local_image_text()

    has_bim = True
    has_pc = True
    has_temporal = "No historical records available" not in temporal_text
    has_local_image = len(valid_items) > 0 and len(annotated_imgs) > 0

    n_types, missing_text = build_input_completeness(
        has_bim=has_bim,
        has_pc=has_pc,
        has_temporal=has_temporal,
        has_local_image=has_local_image,
    )

    prompt = build_final_prompt(
        target_element_text=target_element_text,
        bim_semantics=bim_semantics,
        pointcloud_summary_text=pointcloud_summary_text,
        temporal_text=temporal_text,
        local_image_text=local_image_text,
        n_types=n_types,
        missing_text=missing_text,
        num_views=len(valid_items),
    )

    print("\n===== FINAL PROMPT READY =====\n")
    print(prompt[:20000] + "\n...\n")

    result = call_comp_openai_with_images(prompt, annotated_imgs)

    OUTPUT_JSON_PATH.parent.mkdir(parents=True, exist_ok=True)
    with open(OUTPUT_JSON_PATH, "w", encoding="utf-8") as f:
        json.dump(result, f, ensure_ascii=False, indent=2)

    print(f"\nSaved to: {OUTPUT_JSON_PATH}")
    print(json.dumps(result, ensure_ascii=False, indent=2))

if __name__ == "__main__":
    main()